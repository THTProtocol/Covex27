# ═══════════════════════════════════════════════════════════════════════
# Covex — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════
#
# Copy this file to .env and adjust as needed:
#   cp .env.example .env
#
# The backend reads these vars at startup and connects accordingly.
# ═══════════════════════════════════════════════════════════════════════

# ── Kaspa Network ────────────────────────────────────────────────────
#
# "mainnet"   — Kaspa Mainnet (port 16110, prefix "kaspa")
# "testnet-12" — TN12 Testnet (port 17110, prefix "kaspatest")
#
KASPA_NETWORK=testnet-12

# ── wRPC Node URL ────────────────────────────────────────────────────
#
# Mainnet:   ws://127.0.0.1:16110
# Testnet:   ws://127.0.0.1:17110
#
KASPA_WRPC_URL=ws://127.0.0.1:17110

# ── HTTP Bind ────────────────────────────────────────────────────────
BIND_ADDR=0.0.0.0:3001

# ── Database Path ────────────────────────────────────────────────────
# SQLite database file location. Default: ../covex.db
DB_PATH=../covex.db

# ── Treasury Address ─────────────────────────────────────────────────
# Receives KAS payments for tier upgrades. Auto-monitored by payment verifier.
# TN12: kaspatest:qpyfz03k6quxwf2jglwkhczvt758d8xrq99gl37p6h3vsqur27ltjhn68354m
# Mainnet: kaspa:<your-treasury-address>
COVENANT_TREASURY_ADDRESS=kaspatest:qpyfz03k6quxwf2jglwkhczvt758d8xrq99gl37p6h3vsqur27ltjhn68354m

# ── Seed Addresses for Indexer ───────────────────────────────────────
# Comma-separated list of addresses to monitor for covenant UTXOs.
# Leave empty to only scan blocks for covenant scripts.
COVENANT_SEED_ADDRESSES=

# ── SilverScript Compiler ────────────────────────────────────────────
# Path to the silverc binary (from https://github.com/kaspanet/silverscript)
# Required for the /api/compile endpoint.
SILVERC_PATH=/usr/local/bin/silverc

# ── Logging ──────────────────────────────────────────────────────────
RUST_LOG=covex27_backend=debug,kaspa_wrpc=info

# ── Quick-switch: Mainnet ────────────────────────────────────────────
# Uncomment the lines below to target Mainnet:
#
#   KASPA_NETWORK=mainnet
#   KASPA_WRPC_URL=ws://127.0.0.1:16110
#   COVENANT_TREASURY_ADDRESS=kaspa:<your-mainnet-treasury>
