# ═══════════════════════════════════════════════════════════════════════
# Covex27 — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════
#
# Copy this file to .env and adjust as needed:
#   cp .env.example .env
#
# The backend reads these vars at startup and connects accordingly.
# ═══════════════════════════════════════════════════════════════════════

# ── Kaspa Network ────────────────────────────────────────────────────
#
# "mainnet"   — Kaspa Mainnet (port 16110, prefix "kaspa")
# "testnet-12" — TN12 Testnet (port 17110, prefix "kaspatest")
# "testnet-11" — TN11 Testnet (port 17110, prefix "kaspatest")
# "testnet-10" — TN10 Testnet (port 17110, prefix "kaspatest")
#
KASPA_NETWORK=testnet-12

# ── wRPC Node URL ────────────────────────────────────────────────────
#
# Defaults for common setups:
#   Mainnet:   ws://127.0.0.1:16110
#   Testnet:   ws://127.0.0.1:17110
#
# Point this at any kaspa-node or kaspad instance with wRPC enabled.
#
KASPA_WRPC_URL=ws://127.0.0.1:17110

# ── HTTP Bind ────────────────────────────────────────────────────────
BIND_ADDR=0.0.0.0:3001

# ── Logging ──────────────────────────────────────────────────────────
#
# Set RUST_LOG to control tracing verbosity.
# Examples:
#   RUST_LOG=covex27_backend=debug,kaspa_wrpc=info
#   RUST_LOG=trace
#
RUST_LOG=covex27_backend=debug,kaspa_wrpc=info

# ── Quick-switch: Mainnet ────────────────────────────────────────────
#
# Uncomment (or change .env) the lines below to target Mainnet:
#
#   KASPA_NETWORK=mainnet
#   KASPA_WRPC_URL=ws://127.0.0.1:16110
