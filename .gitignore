# Build artifacts
backend/target/
frontend/dist/
frontend/node_modules/

# Environment files (never commit real secrets)
.env
.env.*
!.env.example

# Database
*.db
*.db-journal
*.db-wal
*.db-shm

# Logs (never commit)
*.log
backend/backend.log
logs/

# Secrets and keys (CRITICAL - never commit these)
**/*seed*
**/*mnemonic*
**/*private*
**/*key*
**/*secret*
*.pem
*.key
id_rsa*

# ZK ceremony artifacts — committed (public verifier data, not secrets)
!frontend/public/zk/merkle_membership/merkle_membership_final.zkey
!frontend/public/zk/merkle_membership/merkle_membership_vkey.json
!frontend/public/zk/range_proof/range_proof_final.zkey

# Chess ZK artifacts (vkey is public verifier data; ptau/zkey/wasm are local build outputs)
zk/games/chess/output/**/*.ptau
zk/games/chess/output/*.ptau
zk/games/chess/output/*.zkey
zk/games/chess/output/chess_v1_build/
zk/games/chess/output/ptau/
!zk/games/chess/output/chess_v1_vkey.json
!zk/chess_v1_vkey.json

# OS files
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo

added-zk-to-gitignore

# Additional security ignores
*.env.production
*.env.local
