# Real verified ZK served artifacts (iter: age_verification + escrow_2party, dev pot10 Groth16, proofs verify)
!frontend/public/zk/age_verification/age_verification.wasm
!frontend/public/zk/age_verification/age_verification_final.zkey
!frontend/public/zk/escrow_2party/escrow_2party.wasm
!frontend/public/zk/escrow_2party/escrow_2party_final.zkey

# New privacy / identity / solvency circuits (dev pot10/pot12 Groth16 ceremony, node-verified
# accept+tamper+replay before registration). The _final.zkey are otherwise caught by **/*key*.
!frontend/public/zk/commitment_open/commitment_open_final.zkey
!frontend/public/zk/balance_threshold/balance_threshold_final.zkey
!frontend/public/zk/solvency_sum/solvency_sum_final.zkey
!frontend/public/zk/set_non_membership/set_non_membership_final.zkey
!frontend/public/zk/anon_membership_nullifier/anon_membership_nullifier_final.zkey

# New self-contained primitives (zkwave 2026-06-28, dev pot10/pot12 ceremony, node-verified
# accept + tamper-reject + false-predicate valid==0 before registration). _final.zkey otherwise
# caught by **/*key*; the served key is the source of truth an in-browser prover uses.
!frontend/public/zk/merkle_range_membership/merkle_range_membership_final.zkey
!frontend/public/zk/equality_of_commitments/equality_of_commitments_final.zkey

# circomwave 2026-06-28 primitives (dev pot10/pot12 ceremony, each proven end-to-end against the
# SERVED wasm+zkey+vkey: accept + tamper-reject + false-predicate valid==0 before registration).
# The _final.zkey is otherwise caught by **/*key*; it is the source of truth the in-browser prover
# + the oracle's strict verify both pair against, so it MUST be committed.
!frontend/public/zk/merkle_multi_membership/merkle_multi_membership_final.zkey
!frontend/public/zk/nullifier_uniqueness/nullifier_uniqueness_final.zkey
!frontend/public/zk/threshold_sig_knowledge/threshold_sig_knowledge_final.zkey
!frontend/public/zk/pedersen_open_equals/pedersen_open_equals_final.zkey
!frontend/public/zk/sorted_merkle_range/sorted_merkle_range_final.zkey
