[Unit]
Description=Run the Covex on-box monitor (covex-watch) every 5 minutes
Documentation=file:///mnt/HC_Volume_105579109/Covex27/docs/MONITORING.md

[Timer]
# Every 5 minutes, aligned to the wall clock. Persistent=true makes systemd run
# the timer once on boot if the box was down across a scheduled tick, so a reboot
# does not silently skip the next check.
OnCalendar=*:0/5
Persistent=true
AccuracySec=30s

[Install]
WantedBy=timers.target
